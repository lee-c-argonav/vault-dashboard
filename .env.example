# Copy to .env and fill in. .env is gitignored and holds machine- and
# account-specific values, so nothing here leaks into the tracked source.
# server.js loads .env at boot; tools.json references these as ${VAR}.

# The Obsidian vault to read and watch (absolute path).
VAULT_HUD_VAULT=/absolute/path/to/your/obsidian/vault
# Port for the local server (default 5959 if unset).
VAULT_HUD_PORT=5959

# --- Action-bar shortcut targets (all optional; a shortcut whose only
# --- URL comes from an unset var simply drops out of the bar) ---

# GitHub org or user page the "GH" button opens.
GITHUB_URL=https://github.com/your-org
# Supabase project dashboard the "SB" button opens.
SUPABASE_DASHBOARD_URL=https://supabase.com/dashboard/project/your_project_ref
# Vercel team/project the "VC" button opens.
VERCEL_URL=https://vercel.com/your-team
# Local dev server the "DEV" button focuses.
DEV_URL=http://localhost:3000/
# Obsidian vault NAME (not path) for the "OB" daily-note deep link.
OBSIDIAN_VAULT=your-vault-name
# Project directory the "TM" (Terminal) and "ED" (VS Code) buttons open.
PROJECT_DIR=/absolute/path/to/your/project
